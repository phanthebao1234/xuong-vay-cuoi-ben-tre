# ============================================================
# Xưởng Váy Cưới Bến Tre — Environment Variables
# Copy to .env.local for local development.
# Set these in the Vercel Dashboard (separate Vercel project) for production.
#
# NEVER put secrets here: no Django SECRET_KEY, no JWT secrets,
# no R2 credentials, no database URLs, no production tokens.
# This frontend consumes the shared FOXIE public API only.
# ============================================================

# ── Shared backend API (FOXIE Django on Railway) ─────────────
# Local dev:      http://localhost:8000
# Production:     https://foxie-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Public site URL (metadataBase / canonical / sitemap) ─────
# Local dev:      http://localhost:3100
# Production:     the project's own custom domain (TBD)
NEXT_PUBLIC_SITE_URL=http://localhost:3100
